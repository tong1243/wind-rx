<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wut.screendbmysqlrx.Mapper.ParametersMapper">
    <select id="createTable" statementType="CALLABLE">
        CREATE TABLE IF NOT EXISTS ${tableName} LIKE parameters;
    </select>

    <select id="dropTable" statementType="CALLABLE">
        DROP TABLE IF EXISTS ${tableName};
    </select>

</mapper>
