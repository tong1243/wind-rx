<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wut.screendbmysqlrx.Mapper.TravelReservationMapper">

    <select id="selectLatestReservation" resultType="com.wut.screendbmysqlrx.Model.TravelReservation">
        SELECT
            id,
            user_phone,
            car_license
        FROM travel_reservation
        ORDER BY id DESC
        LIMIT 1
    </select>

</mapper>
